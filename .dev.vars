# Shared secret — must match WEBHOOK_SECRET in the Teacher App's .dev.vars
WEBHOOK_SECRET="SRCC_TEACHER_ASSIST_SECRET_2026"

# Webhook target URLs — update these to the deployed production URLs before going live.
# For local dev, point to the other app's local wrangler dev port (default 8788).
TEACHER_APP_WEBHOOK_URL="http://localhost:8788/api/webhook/absence"
STUDENT_APP_WEBHOOK_URL=""
